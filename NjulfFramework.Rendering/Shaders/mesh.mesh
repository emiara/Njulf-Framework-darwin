// SPDX-License-Identifier: MPL-2.0

#version 460
#extension GL_EXT_mesh_shader : require
#extension GL_EXT_nonuniform_qualifier : require

layout(local_size_x = 128) in;
layout(max_vertices = 128, max_primitives = 64) out;
layout(triangles) out;

layout(set = 0, binding = 0) readonly buffer BufferHeap { uint data[]; } buffers[65536];

layout(push_constant) uniform PushConstants
{
    mat4 view;
    mat4 projection;
    uint screenWidth;
    uint screenHeight;
    uint debugMeshlets;
    uint lightCount;
    uint lightBufferIndex;
    uint tiledLightHeaderBufferIndex;
    uint tiledLightIndicesBufferIndex;
    uint instanceBufferIndex;
    uint meshletDrawBufferIndex;
    uint meshletDrawCount;
    uint pad0;
    uint pad1;
} pc;

struct Payload { uint instanceIndex; uint meshletIndex; };
taskPayloadSharedEXT Payload payload;

layout(location = 0) out vec3 outPosition[];
layout(location = 1) out vec3 outNormal[];
layout(location = 2) out vec2 outTexCoord[];
layout(location = 3) out flat uint outMaterialIndex[];
layout(location = 4) out flat uint outMeshletIndex[];

const uint MESHLET_STRIDE = 24u; // 96 bytes
const uint INSTANCE_STRIDE = 20u; // 80 bytes

uint meshletField(uint meshletIndex, uint field) {
    return buffers[5u].data[meshletIndex * MESHLET_STRIDE + field];
}

mat4 getInstanceModel(uint instanceIndex) {
    uint base = instanceIndex * INSTANCE_STRIDE;
    mat4 m;
    for (int i = 0; i < 16; i++)
        m[i / 4][i % 4] = uintBitsToFloat(buffers[pc.instanceBufferIndex].data[base + uint(i)]);
    return m;
}

uint getInstanceMaterial(uint instanceIndex) {
    return buffers[pc.instanceBufferIndex].data[instanceIndex * INSTANCE_STRIDE + 16u];
}

void unpackVertex(uint vertexIndex, out vec3 position, out vec3 normal, out vec2 texCoord)
{
    uint base = vertexIndex * 8u; // 32-byte vertex
    position = vec3(
        uintBitsToFloat(buffers[3u].data[base + 0u]),
        uintBitsToFloat(buffers[3u].data[base + 1u]),
        uintBitsToFloat(buffers[3u].data[base + 2u]));
    normal = vec3(
        uintBitsToFloat(buffers[3u].data[base + 3u]),
        uintBitsToFloat(buffers[3u].data[base + 4u]),
        uintBitsToFloat(buffers[3u].data[base + 5u]));
    texCoord = vec2(
        uintBitsToFloat(buffers[3u].data[base + 6u]),
        1.0 - uintBitsToFloat(buffers[3u].data[base + 7u]));
}

void main()
{
    uint instanceIndex = payload.instanceIndex;
    uint meshletIndex  = payload.meshletIndex;

    uint vertexOffset   = meshletField(meshletIndex, 0u);
    uint vertexCount    = meshletField(meshletIndex, 1u);
    uint triangleOffset = meshletField(meshletIndex, 2u);
    uint triangleCount  = meshletField(meshletIndex, 3u);
    uint baseVertex     = meshletField(meshletIndex, 4u); // baked absolute base into consolidated vertex buffer

    if (gl_LocalInvocationIndex == 0u)
        SetMeshOutputsEXT(vertexCount, triangleCount);

    if (triangleCount == 0u)
        return;

    mat4 model = getInstanceModel(instanceIndex);
    uint materialIndex = getInstanceMaterial(instanceIndex);
    mat4 mvp = pc.projection * pc.view * model;

    uint localIndex = gl_LocalInvocationIndex;
    if (localIndex < vertexCount)
    {
        // meshlet vertex index is mesh-LOCAL; add the meshlet's baked baseVertex.
        uint meshLocalVertex = buffers[6u].data[vertexOffset + localIndex];
        uint globalVertexIndex = baseVertex + meshLocalVertex;

        vec3 pos; vec3 normal; vec2 uv;
        unpackVertex(globalVertexIndex, pos, normal, uv);

        gl_MeshVerticesEXT[localIndex].gl_Position = mvp * vec4(pos, 1.0);
        outPosition[localIndex] = vec3(model * vec4(pos, 1.0));
        outNormal[localIndex] = normalize(mat3(model) * normal);
        outTexCoord[localIndex] = uv;
        outMaterialIndex[localIndex] = materialIndex;
        outMeshletIndex[localIndex] = meshletIndex;
    }

    if (localIndex < triangleCount)
    {
        uint triBase = triangleOffset + localIndex * 3u;
        uint l0 = buffers[7u].data[triBase + 0u];
        uint l1 = buffers[7u].data[triBase + 1u];
        uint l2 = buffers[7u].data[triBase + 2u];
        gl_PrimitiveTriangleIndicesEXT[localIndex] = uvec3(l0, l1, l2);
    }
}
