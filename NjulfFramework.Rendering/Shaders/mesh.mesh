#version 460
#extension GL_EXT_mesh_shader : require
#extension GL_EXT_nonuniform_qualifier : require

layout(local_size_x = 128) in;
layout(max_vertices = 128, max_primitives = 64) out;
layout(triangles) out;

struct GPUMeshlet
{
    uint vertexOffset;
    uint vertexCount;
    uint triangleOffset;
    uint triangleCount;
    vec4 boundsMin;
    vec4 boundsMax;
    vec4 coneAxis;
    vec4 coneData;
};

// Bindless buffer heap (set 0, binding 0)
// Index 3: Vertex buffer
// Index 4: Index buffer
// Index 5: Meshlet buffer
// Index 6: Meshlet vertex index buffer
// Index 7: Meshlet triangle index buffer
layout(set = 0, binding = 0) readonly buffer BufferHeap
{
    uint data[];
} buffers[65536];

// Push constants
layout(push_constant) uniform PushConstants
{
    mat4 model;
    mat4 view;
    mat4 projection;
    uint materialIndex;
    uint vertexOffset;
    uint indexOffset;
    uint indexCount;
    uint vertexCount;
    uint meshletOffset;
    uint meshletCount;
    float meshBoundsRadius;
    uint screenWidth;
    uint screenHeight;
    uint debugMeshlets;
    uint lightCount;
    uint lightBufferIndex;
    uint tiledLightHeaderBufferIndex;
    uint tiledLightIndicesBufferIndex;
    uint padding;
} pc;

layout(location = 0) out vec3 outPosition[];
layout(location = 1) out vec3 outNormal[];
layout(location = 2) out vec2 outTexCoord[];
layout(location = 3) out flat uint outMaterialIndex[];
layout(location = 4) out flat uint outMeshletIndex[];

// GPUMeshlet is 80 bytes = 20 uints
// Field offsets in uints:
//   vertexOffset:       0
//   vertexCount:        1
//   triangleOffset:     2
//   triangleCount:      3
//   boundsMin:          4-7 (vec4 = 4 uints)
//   boundsMax:          8-11 (vec4)
//   coneAxis:           12-15 (vec4)
//   coneData:           16-19 (vec4)

uint getMeshletVertexOffset(uint meshletIndex)
{
    return buffers[5u].data[meshletIndex * 20u + 0u];
}

uint getMeshletVertexCount(uint meshletIndex)
{
    return buffers[5u].data[meshletIndex * 20u + 1u];
}

uint getMeshletTriangleOffset(uint meshletIndex)
{
    return buffers[5u].data[meshletIndex * 20u + 2u];
}

uint getMeshletTriangleCount(uint meshletIndex)
{
    return buffers[5u].data[meshletIndex * 20u + 3u];
}

// Vertex is 32 bytes = 8 uints (each float = 1 uint in bit representation)
// Layout: Position(x,y,z), Normal(x,y,z), TexCoord(x,y)
//   uint[0-2]:  position.x, position.y, position.z (as float bits)
//   uint[3-5]:  normal.x, normal.y, normal.z (as float bits)
//   uint[6-7]:  texCoord.x, texCoord.y (as float bits)
//void unpackVertex(uint vertexIndex, out vec3 position, out vec3 normal, out vec2 texCoord)
//{
//    uint base = vertexIndex * 8u;
//    position = vec3(
//        uintBitsToFloat(buffers[3u].data[base + 0u]),
//        uintBitsToFloat(buffers[3u].data[base + 1u]),
//        uintBitsToFloat(buffers[3u].data[base + 2u])
//    );
//    normal = vec3(
//        uintBitsToFloat(buffers[3u].data[base + 3u]),
//        uintBitsToFloat(buffers[3u].data[base + 4u]),
//        uintBitsToFloat(buffers[3u].data[base + 5u])
//    );
//    texCoord = vec2(
//        uintBitsToFloat(buffers[3u].data[base + 6u]),
//        uintBitsToFloat(buffers[3u].data[base + 7u])
//    );
//}

// Vertex is 40 bytes = 10 uints (with padding)
void unpackVertex(uint vertexIndex, out vec3 position, out vec3 normal, out vec2 texCoord)
{
    uint base = vertexIndex * 8u;

    // Position (offset 0, 4, 8 in bytes = uints 0, 1, 2)
    position = vec3(
        uintBitsToFloat(buffers[3u].data[base + 0u]),
        uintBitsToFloat(buffers[3u].data[base + 1u]),
        uintBitsToFloat(buffers[3u].data[base + 2u])
    );

    // Skip padding (uint 3 is padding)
    // Normal (offset 16, 20, 24 in bytes = uints 4, 5, 6)
    normal = vec3(
        uintBitsToFloat(buffers[3u].data[base + 4u]),
        uintBitsToFloat(buffers[3u].data[base + 5u]),
        uintBitsToFloat(buffers[3u].data[base + 6u])
    );

    // Skip padding (uint 7 is padding)
    // TexCoord (offset 28, 32 in bytes = uints 8, 9)
    texCoord = vec2(
        uintBitsToFloat(buffers[3u].data[base + 8u]),
        uintBitsToFloat(buffers[3u].data[base + 9u])
    );
}

void main()
{
    if (gl_WorkGroupID.x >= pc.meshletCount)
    {
        if (gl_LocalInvocationIndex == 0u)
        {
            SetMeshOutputsEXT(0, 0);
        }
        return;
    }

    uint meshletIndex = pc.meshletOffset + gl_WorkGroupID.x;
    uint vertexOffset = getMeshletVertexOffset(meshletIndex);
    uint vertexCount = getMeshletVertexCount(meshletIndex);
    uint triangleOffset = getMeshletTriangleOffset(meshletIndex);
    uint triangleCount = getMeshletTriangleCount(meshletIndex);

    bool culled = false;
    if (gl_LocalInvocationIndex == 0u)
    {
        if (culled)
            SetMeshOutputsEXT(0, 0);
        else
            SetMeshOutputsEXT(vertexCount, triangleCount);
    }

    if (culled)
        return;

    if (triangleCount == 0u)
        return;

    uint localIndex = gl_LocalInvocationIndex;
    if (localIndex < vertexCount)
    {
        uint meshletVertexIndex = buffers[6u].data[vertexOffset + localIndex];
        uint globalVertexIndex = meshletVertexIndex + pc.vertexOffset;
        vec3 pos;
        vec3 normal;
        vec2 uv;
        unpackVertex(globalVertexIndex, pos, normal, uv);
        gl_MeshVerticesEXT[localIndex].gl_Position = pc.projection * pc.view * pc.model * vec4(pos, 1.0);
        outPosition[localIndex] = vec3(pc.model * vec4(pos, 1.0));
        outNormal[localIndex] = normalize(mat3(pc.model) * normal);
        outTexCoord[localIndex] = uv;
        outMaterialIndex[localIndex] = pc.materialIndex;
        outMeshletIndex[localIndex] = meshletIndex;
    }

    if (localIndex < triangleCount)
    {
        uint triBase = triangleOffset + localIndex * 3u;
        uint l0 = buffers[7u].data[triBase + 0u];
        uint l1 = buffers[7u].data[triBase + 1u];
        uint l2 = buffers[7u].data[triBase + 2u];
        gl_PrimitiveTriangleIndicesEXT[localIndex] = uvec3(l0, l1, l2);
    }
}
