# Set the default behavior to handle all files as text and force LF
* text=auto eol=lf

# (Optional) Explicitly mark binary files so they aren't touched
*.png binary
*.jpg binary
*.jpg filter=lfs diff=lfs merge=lfs -text
*.png filter=lfs diff=lfs merge=lfs -text
*.gltf filter=lfs diff=lfs merge=lfs -text
*.glb filter=lfs diff=lfs merge=lfs -text
